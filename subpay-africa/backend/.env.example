# ============================================================
# SubPay Africa - Environment Variables
# ============================================================
# Copier ce fichier en .env et remplir les valeurs

# Application
NODE_ENV=development
PORT=3000
APP_URL=https://api.subpay.africa
FRONTEND_URL=https://app.subpay.africa

# Database PostgreSQL
DATABASE_URL=postgresql://subpay:subpay_password@localhost:5432/subpay_africa

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# PAIEMENT — Orange Money
# ============================================================
# Cameroun
ORANGE_CLIENT_ID_CM=
ORANGE_CLIENT_SECRET_CM=
ORANGE_MERCHANT_KEY_CM=
# RDC (Congo DRC)
ORANGE_CLIENT_ID_CD=
ORANGE_CLIENT_SECRET_CD=
ORANGE_MERCHANT_KEY_CD=
# Burkina Faso
ORANGE_CLIENT_ID_BF=
ORANGE_CLIENT_SECRET_BF=
ORANGE_MERCHANT_KEY_BF=

# ============================================================
# PAIEMENT — MTN Mobile Money
# ============================================================
MTN_API_BASE_URL=https://sandbox.momodeveloper.mtn.com
# Cameroun
MTN_SUBSCRIPTION_KEY_COLLECTION_CM=
MTN_API_USER_CM=
MTN_API_KEY_CM=
# Congo-Brazzaville
MTN_SUBSCRIPTION_KEY_COLLECTION_CG=
MTN_API_USER_CG=
MTN_API_KEY_CG=
MTN_TARGET_ENV=sandbox

# ============================================================
# PAIEMENT — Airtel Money
# ============================================================
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_API_BASE_URL=https://openapi.airtel.africa

# ============================================================
# ABONNEMENTS — Reloadly
# ============================================================
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=
RELOADLY_ENV=sandbox
# sandbox: https://giftcards-sandbox.reloadly.com
# production: https://giftcards.reloadly.com
RELOADLY_BASE_URL=https://giftcards-sandbox.reloadly.com
RELOADLY_AUTH_URL=https://auth.reloadly.com/oauth/token

# Reloadly Product IDs (sandbox)
RELOADLY_NETFLIX_PRODUCT_ID=10
RELOADLY_SPOTIFY_PRODUCT_ID=1839
RELOADLY_APPLE_MUSIC_PRODUCT_ID=12
RELOADLY_PSN_PRODUCT_ID=532

# ============================================================
# TAUX DE CHANGE
# ============================================================
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

# ============================================================
# NOTIFICATIONS
# ============================================================
# Expo Push Notifications
EXPO_ACCESS_TOKEN=

# Africa's Talking (SMS)
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=sandbox

# ============================================================
# SÉCURITÉ
# ============================================================
ENCRYPTION_KEY=your-32-char-encryption-key-here!
WEBHOOK_SECRET_ORANGE=
WEBHOOK_SECRET_MTN=
WEBHOOK_SECRET_AIRTEL=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
